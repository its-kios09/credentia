generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Practitioner {
  id                  String   @id @default(uuid()) @db.Uuid
  puid                String   @unique
  registrationId      String   @unique @map("registration_id")
  externalReferenceId String?  @map("external_reference_id")
  firstName           String   @map("first_name")
  middleName          String?  @map("middle_name")
  lastName            String   @map("last_name")
  fullName            String   @map("full_name")
  gender              String?
  licensingBody       String   @map("licensing_body")
  specialty           String?
  isActive            Boolean  @default(true) @map("is_active")
  version             Int      @default(0)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("practitioners")
}

model License {
  id                  String   @id @default(uuid()) @db.Uuid
  practitionerId      String   @map("practitioner_id") @db.Uuid
  licenseId           String   @unique @map("license_id")
  externalReferenceId String?  @map("external_reference_id")
  licenseType         String   @map("license_type")
  licenseStart        DateTime @map("license_start") @db.Date
  licenseEnd          DateTime @map("license_end") @db.Date
  status              String   @default("active")
  version             Int      @default(0)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  issuerId            String?  @map("issuer_id")

  @@map("licenses")
}

model VerificationEvent {
  id             String   @id @default(uuid()) @db.Uuid
  practitionerId String?  @map("practitioner_id") @db.Uuid
  licenseId      String?  @map("license_id")
  queryValue     String   @map("query_value")
  result         String
  region         String?
  verifierId     String?  @map("verifier_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("verification_events")
}

model RegulatoryBody {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  name      String
  country   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("regulatory_bodies")
}

model Verifier {
  id           String   @id @default(uuid()) @db.Uuid
  orgName      String   @map("org_name")
  apiKeyHash   String   @unique @map("api_key_hash")
  keyPrefix    String   @map("key_prefix")
  plan         String   @default("free")
  monthlyQuota Int      @default(100) @map("monthly_quota")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("verifiers")
}
